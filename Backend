
const express = require('express');
const mongoose = require('mongoose');
const cors = require('cors');
require('dotenv').config();

const app = express();

// Middleware
app.use(cors()); // Allows frontend to talk to backend
app.use(express.json()); // Allows backend to read JSON data

// 1. Database Connection (MongoDB)
// Use your MongoDB Atlas URI or a local one: 'mongodb://localhost:27017/campuslink'
const MONGO_URI = process.env.MONGO_URI || 'mongodb://localhost:27017/campuslink';

mongoose.connect(MONGO_URI)
    .then(() => console.log('✅ Connected to MongoDB Database'))
    .catch(err => console.error('❌ Database connection error:', err));

// 2. Data Models (Schemas)
const JobSchema = new mongoose.Schema({
    company: String,
    role: String,
    salary: String,
    location: String,
    postedAt: { type: Date, default: Date.now }
});

const StudentSchema = new mongoose.Schema({
    name: String,
    email: { type: String, unique: true },
    appliedJobs: [{ type: mongoose.Schema.Types.ObjectId, ref: 'Job' }]
});

const Job = mongoose.model('Job', JobSchema);
const Student = mongoose.model('Student', StudentSchema);

// 3. API Endpoints (The "Backend Features")

// Get all Jobs
app.get('/api/jobs', async (req, res) => {
    try {
        const jobs = await Job.find().sort({ postedAt: -1 });
        res.json(jobs);
    } catch (err) {
        res.status(500).json({ message: "Server Error fetching jobs" });
    }
});

// Register a Student
app.post('/api/register', async (req, res) => {
    try {
        const newStudent = new Student(req.body);
        await newStudent.save();
        res.status(201).json({ message: "Student Registered Successfully", data: newStudent });
    } catch (err) {
        res.status(400).json({ error: "Email already exists" });
    }
});

// Apply for a Job
app.post('/api/apply', async (req, res) => {
    const { studentId, jobId } = req.body;
    try {
        const student = await Student.findById(studentId);
        if (!student.appliedJobs.includes(jobId)) {
            student.appliedJobs.push(jobId);
            await student.save();
            res.json({ message: "Application Sent!" });
        } else {
            res.status(400).json({ message: "Already Applied" });
        }
    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});

// 4. Start Server
const PORT = process.env.PORT || 5000;
app.listen(PORT, () => {
    console.log(`🚀 Server moving on http://localhost:${PORT}`);
});
